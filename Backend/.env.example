# Database
DATABASE_URL="postgresql://user:pass@host:port/dbname"

# Security
SECRET_KEY="your-secret-key-here"
GRIP_SECRET="your-webhook-secret"
ENVIRONMENT="local"

# AI Features
# AI Features (Local SmolLM2-1.7B)
USE_AI_FORECASTING=true
ENABLE_SCHEDULER=true  # Set to false when using external cron (e.g., GitHub Actions)
GROQ_API_KEY="your-groq-api-key" # Fallback if local LLM is disabled
GROQ_MODEL="llama-3.3-70b-versatile"

X_GRIP_HF_LLM_TOKEN= # Optional: Space-to-space auth token
EMAIL_RELAY_URL="" # Optional: External email relay (ports 25/587 often blocked on cloud)
EMAIL_RELAY_SECRET="the-secret-you-chose"

# Gmail OAuth & Webhooks (for Real-time Sync)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
FRONTEND_ORIGIN="http://localhost:5173"  # Must match Google Console
GMAIL_PUBSUB_TOPIC="projects/your-project/topics/gmail-updates"

# Email (for OTP verification)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
FROM_EMAIL="noreply@grip.com"
FROM_NAME="Grip"

# Branding (customize your app)
APP_NAME="Grip"
APP_TAGLINE="Money that minds itself."